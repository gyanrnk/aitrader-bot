# Copy to .env and fill in. Nothing here is required for mock/paper mode.

# --- Reasoning backend (the LLM is OPTIONAL and off the trading loop by default) ---
# quant  = no LLM, pure signals            FREE   (default; this is what trades)
# groq   = Groq API, free tier             FREE   (get key at console.groq.com)
# claude = Anthropic API                   PAID
AITRADER_LLM_BACKEND=quant

# Set to 1 ONLY if you want the LLM to run on every bar (costs money on groq/claude).
# Leave 0 for real trading: LLM is used only by the slow loop (regime/news/reflection).
AITRADER_USE_LLM_IN_DECISION=0

# --- Groq (free tier) ---
GROQ_API_KEY=
AITRADER_GROQ_MODEL=llama-3.3-70b-versatile

# --- Claude (paid, optional) ---
ANTHROPIC_API_KEY=
AITRADER_LLM_MODEL=claude-sonnet-5

# --- Run mode ---
# mock  = synthetic data + free engine, no network, no keys (default)
# live  = real data provider (+ LLM if a backend is configured)
AITRADER_MODE=mock

# --- Data provider: mock | yfinance ---
AITRADER_DATA_PROVIDER=mock

# --- Broker/execution: paper | ccxt ---
AITRADER_BROKER=paper

# --- ccxt (only if AITRADER_BROKER=ccxt) ---
CCXT_EXCHANGE=binance
CCXT_API_KEY=
CCXT_SECRET=

# --- Risk limits ---
AITRADER_MAX_POSITION_PCT=0.20      # max % of equity in one position
AITRADER_RISK_PER_TRADE_PCT=0.01    # fraction of equity risked per trade
AITRADER_MAX_GROSS_EXPOSURE=1.0     # 1.0 = no leverage

# --- Costs (used everywhere P&L is reported) ---
AITRADER_COST_BPS_PER_SIDE=5        # transaction cost, basis points per side
